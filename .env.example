PORT=3010

# ─── Supabase ───────────────────────────────────────────────
# Dapatkan dari: https://supabase.com/dashboard/project/<project_ref>/settings/api
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key

# ─── Gemini AI ──────────────────────────────────────────────
# Dapatkan dari: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
VITE_GEMINI_API_KEY=your_gemini_api_key

# ─── OpenRouter ─────────────────────────────────────────────
# Dapatkan dari: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key
VITE_OPENROUTER_API_KEY=your_openrouter_api_key

# ─── OpenRouter Models ──────────────────────────────────────
# writing/utility tools (caption, hook, bio, reply, script, dll)
VITE_OPENROUTER_MODEL_SCRIPT=meta-llama/llama-3.3-70b-instruct:free
# analyzer tools (competitor, trend, shadowban, affiliate, dll)
VITE_OPENROUTER_MODEL_SEARCH=meta-llama/llama-3.3-70b-instruct:free
# image/visual tools
VITE_OPENROUTER_MODEL_IMAGE=meta-llama/llama-3.3-70b-instruct:free
# clipper/video tools
VITE_OPENROUTER_MODEL_CLIPPER=meta-llama/llama-3.3-70b-instruct:free

# ─── Admin Credentials ──────────────────────────────────────
VITE_ADMIN_EMAIL=admin@yourdomain.com
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD=your_admin_password
VITE_ADMIN_TOKENS=10000

# ─── Referral System ────────────────────────────────────────
VITE_REFERRAL_BONUS_PERCENT=20

# RunPod API (separate keys by pipeline)
RUNPOD_IMAGE_API_KEY=your_runpod_image_api_key
RUNPOD_VIDEO_API_KEY=your_runpod_video_api_key
# Backward compatibility (optional)
RUNPOD_API_KEY=your_runpod_fallback_api_key
RUNPOD_ENDPOINT_ID=seedream-v4-edit

# OpenClaw (OpenAI-compatible endpoint)
# Example base URL:
# - local gateway: http://127.0.0.1:3001
# - direct v1 URL: http://127.0.0.1:3001/v1
OPENCLAW_BASE_URL=http://127.0.0.1:3001
OPENCLAW_API_KEY=your_openclaw_api_key
OPENCLAW_MODEL=gpt-4o-mini

